# Per-machine secrets and API keys.
#
# Copy this file to ~/.config/secrets/env and fill in your real values.
# The bootstrap script does this for you on first run; afterwards, edit
# ~/.config/secrets/env directly. NEVER commit your filled copy.
#
# File mode MUST be 0600. The 60-secrets.zsh loader will warn if it isn't.
#
#   mkdir -p ~/.config/secrets
#   cp secrets/env.example ~/.config/secrets/env
#   chmod 600 ~/.config/secrets/env
#
# This file is sourced verbatim by zsh — use plain `export KEY=value` lines
# (no spaces around `=`, quote values with spaces).

# --- AI / Coding agents ---------------------------------------------------
# export ANTHROPIC_API_KEY=""
# export OPENAI_API_KEY=""
# export GEMINI_API_KEY=""

# --- GitHub / Git hosting -------------------------------------------------
# `gh auth login` stores its own token; only set GH_TOKEN here if you need
# a non-interactive PAT for scripts/CI.
# export GH_TOKEN=""

# --- Cloud providers ------------------------------------------------------
# Prefer `aws sso login` / `gcloud auth` over long-lived keys when possible.
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export AWS_DEFAULT_REGION="us-east-1"

# --- Other ---------------------------------------------------------------
# export TF_VAR_someval=""
