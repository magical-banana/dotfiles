# Per-machine identity lives in ~/.gitconfig.local (gitignored, generated by
# scripts/50-git.sh on first run). Settings here apply to every machine.
#
# IMPORTANT: this path is intentionally absolute (with ~ expansion) rather
# than relative. When ~/.gitconfig is a symlink (always, in this repo),
# git resolves relative include paths against the SYMLINK TARGET's
# directory — which lives inside the dotfiles repo — and silently misses
# the actual ~/.gitconfig.local file. Tilde-prefixed paths bypass that.
[include]
    path = ~/.gitconfig.local

[core]
    editor = vim
    # Tighten line-ending behavior: in repos checked out on Linux/WSL, store
    # files with LF and reject CRLF on commit. The repo's .gitattributes
    # also enforces this, but having it at the user level catches files in
    # repos that don't have a .gitattributes yet.
    autocrlf = input
    # Faster `git status` on large repos
    untrackedCache = true
    # Use delta for paged output if installed (no-op when delta is missing —
    # `pager` falls through to less). Tooling-friendly defaults.
    pager = "delta || less"

[init]
    defaultBranch = main

[pull]
    rebase = true            # cleaner history; no merge bubbles on `git pull`

[push]
    default = current        # `git push` only the current branch
    autoSetupRemote = true   # `git push` on a new branch sets upstream automatically
    followTags = true        # push annotated tags reachable from pushed commits

[fetch]
    prune = true             # auto-delete local refs to gone remote branches
    pruneTags = true

[merge]
    conflictstyle = zdiff3   # 3-way conflict markers (much easier to resolve)

[rerere]
    enabled = true           # remember conflict resolutions across rebases
    autoupdate = true

[diff]
    algorithm = histogram    # smarter than the default Myers algorithm
    colorMoved = default     # highlight moved lines in a different color
    renames = copies

[rebase]
    autoSquash = true        # `fixup!` / `squash!` commits auto-arrange on rebase
    autoStash = true         # auto-stash dirty tree before rebase, pop after
    updateRefs = true        # rebase stacks of branches together

[branch]
    sort = -committerdate    # `git branch` lists most-recently-used first

[column]
    ui = auto                # multi-column output for branch/tag listings

[color]
    ui = auto

# --- Delta integration (used if `delta` is on PATH; harmless otherwise) ---
[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    # bat doesn't ship a native Gotham theme; OneHalfDark is the closest
    # built-in pair (deep blue/teal). To install a real Gotham .tmTheme:
    #   1. drop a Gotham.tmTheme into ~/.config/bat/themes/
    #   2. run `bat cache --build`
    #   3. change this line to: syntax-theme = "Gotham"
    syntax-theme = "OneHalfDark"
    # Highlight palette tuned to Gotham
    minus-style                   = syntax "#1c1014"
    minus-emph-style              = syntax "#3a1014"
    plus-style                    = syntax "#0a3749"
    plus-emph-style               = syntax "#1e6479"
    file-style                    = "#33859e" bold
    file-decoration-style         = "#091f2e" ul
    hunk-header-style             = "#edb443" bold

# --- Aliases ---
[alias]
    # Status & staging
    st = status -sb
    co = checkout
    sw = switch
    br = branch
    ci = commit
    addall = !git add . && git status -sb

    # History
    ll = log --oneline --graph --all --decorate
    hist = log -p --decorate
    last = log -1 HEAD --stat
    ls-last = !git diff-tree --no-commit-id --name-only -r HEAD

    # Safety / amendments
    undo = reset HEAD^
    amend = commit --amend --no-edit
    fixup = commit --fixup

    # Stashing
    sa = stash push -u
    sp = stash pop
    sl = stash list

    # PR/branch workflow (relies on `gh`)
    pr = "!f() { gh pr create \"$@\"; }; f"
    prv = "!f() { gh pr view --web \"$@\"; }; f"

# --- GitHub CLI as credential helper ---
# `gh auth login` writes here automatically; this stanza just makes sure the
# user-level config doesn't override it.
[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential
